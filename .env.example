AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Azure AI Speech (Text-to-Speech Avatar) — for the "Talking Cindy" page ---
# Create a Speech resource in Southeast Asia (southeastasia) — the photoreal
# real-time avatar is only supported in West US 2, West Europe, and Southeast
# Asia. Australia East / Australia Southeast are NOT supported. Southeast Asia
# (Singapore) is the closest supported region for Australian presenters.
# Note: in the Azure portal the region displays as "Southeast Asia" (with a
# space) but the value used here and in code is "southeastasia" (one word).
# Recommendation: create your Azure OpenAI resource in the same region for
# low-latency interaction between the two services.
AZURE_SPEECH_KEY=your-speech-key-here
AZURE_SPEECH_REGION=southeastasia
AZURE_AVATAR_CHARACTER=lisa
AZURE_AVATAR_STYLE=casual-sitting
# Australian English voice — natural Australian accent, female.
# Alternatives: en-AU-WilliamNeural (male), en-AU-FreyaNeural, en-AU-CarlyNeural
AZURE_TTS_VOICE=en-AU-NatashaNeural
